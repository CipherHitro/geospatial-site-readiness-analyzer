# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/dbname
# Or alternatively:
# PG_URL=postgresql://user:password@localhost/dbname

# API Keys for External Services
# ------------------------------

# OpenRouteService API Key (for isochrone/routing)
ORS_API_KEY=your_openrouteservice_api_key_here

# Geoapify API Key (for catchment/isochrone analysis)
GEOAPIFY_API_KEY=your_geoapify_api_key_here
# Optional: Set to false if you encounter SSL certificate issues
# GEOAPIFY_SSL_VERIFY=true

# Groq API Key (for AI orchestration/insights)
GROQ_API_KEY=your_groq_api_key_here

# World Air Quality Index (WAQI) Token (for environmental risk scores)
WAQI_TOKEN=your_waqi_token_here
